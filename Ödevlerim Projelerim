6.Verilen iki tam sayıyı çıkarma operatörü kullanarak bölen bir C programı yazınız.

#include <stdio.h>

int main()
{
    int bolunen, bolen;
    int bolum = 0;
    int kalan;

    printf("Bolunecek sayiyi girin: ");
    scanf("%d", &bolunen);
    printf("Bolen sayiyi girin: ");
    scanf("%d", &bolen);

    
    if (bolen == 0)
    {
        printf("Hata: Bir sayi 0'a bolunemez!\n");
    }
    else
    {
        kalan = bolunen;

        while (kalan >= bolen)
        {
            kalan = kalan - bolen; 
            bolum++;              
        }

        printf("Sonuc: %d / %d\n", bolunen, bolen);
        printf("Bolum: %d\n", bolum);
        printf("Kalan: %d\n", kalan);
    }

    return 0;
}


