9. İlk 100 asal sayının toplamını hesaplamak için bir C programı yazınız.

#include <stdio.h>

int main() {
    int sayi = 2;     
    int bulunan = 0;   
    long toplam = 0;   
    while (bulunan < 100) {
        int asalMi = 1; // Başlangıçta asal kabul ediyoruz

       
        for (int i = 2; i * i <= sayi; i++) {
            if (sayi % i == 0) {
                asalMi = 0; // Bir sayıya tam bölünürse asal değildir
                break;
            }
        }

       
        if (asalMi == 1) {
            toplam += sayi;
            bulunan++;
        }

        sayi++;     }

    printf("İlk 100 asal sayının toplamı: %ld\n", toplam);

    return 0;
}

10. Tam sayı bir numarayı tersine çevirmek için bir C programı yazınız. 

#include <stdio.h>

int main()
{
    int sayi, tersi = 0, kalan;

    printf("Bir sayi giriniz: ");
    scanf("%d", &sayi);

    while (sayi != 0)
    {
        kalan = sayi % 10;          
        tersi = tersi * 10 + kalan; 
        sayi = sayi / 10;           
    }

    printf("Sayinin tersi: %d\n", tersi);

    return 0;
}

11. Verilen pozitif sayıdan küçük olan asal sayıların adedini saymak için bir C programı yazın.

#include <stdio.h>
int main()
{
    int limit, adet = 0;
    printf("Bir sayi giriniz: ");
    scanf("%d", &limit);
    for (int i = 2; i < limit; i++)
    {
        int asalMi = 1; 
        for (int j = 2; j * j <= i; j++)
        {
            if (i % j == 0)
            {
                asalMi = 0;
                break;
            }
        }
        if (asalMi == 1)
        {
            adet++;
        }
    }
    printf("%d sayisindan kucuk olan toplam asal sayi adedi: %d\n", limit, adet);
    return 0;
}

