SORU 2.POZİTİF TAM SAYİYİ OKUYARAK BU SAYININ KAÇ KAÇ HANELİ OLDUGUNU BULAN BİR 
#include <stdio.h>

int main()
{
    int sayi, basamak = 0;

    printf("Pozitif bir sayi gir: ");
    scanf("%d", &sayi);

